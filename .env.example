# Application
APP_NAME=AI Reputation Manager
APP_ENV=development
APP_DEBUG=True
SECRET_KEY=change_me

# Flask
FLASK_APP=app/app.py

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=reputation_db
DB_USER=reputation_user
DB_PASSWORD=reputation_password

# Gemini
GEMINI_API_KEY=your_gemini_api_key
AI_PROVIDER=gemini
AI_MODEL_NAME=gemini-2.5-flash
AI_BATCH_SIZE=25
AI_WORKER_POLL_SECONDS=5
GEMINI_FLASH_INPUT_COST_PER_1M=0.30
GEMINI_FLASH_OUTPUT_COST_PER_1M=2.50

# Quota placeholders. 0 means not enforced yet.
MAX_REVIEWS_PER_MONTH=0
MAX_AI_REQUESTS_PER_MONTH=0
MAX_TOKENS_PER_MONTH=0

# Manual UPI subscription payments
UPI_ID=dharaprasath52@okhdfcbank
SUBSCRIPTION_PRICE=2999

# Login rate limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
LOGIN_WINDOW_MINUTES=15

# Google Business Profile OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/business.manage

# Upload Settings
MAX_UPLOAD_SIZE=10485760
