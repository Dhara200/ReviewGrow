RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Layered login throttling (positive integers; durations are seconds).
LOGIN_IP_MAX_ATTEMPTS=20
LOGIN_IP_WINDOW_SECONDS=900
LOGIN_IP_BLOCK_SECONDS=900
LOGIN_ACCOUNT_MAX_ATTEMPTS=15
LOGIN_ACCOUNT_WINDOW_SECONDS=900
LOGIN_ACCOUNT_BLOCK_SECONDS=900
LOGIN_IP_ACCOUNT_MAX_ATTEMPTS=5
LOGIN_IP_ACCOUNT_WINDOW_SECONDS=900
LOGIN_IP_ACCOUNT_BLOCK_SECONDS=900
# Optional stable Werkzeug scrypt/pbkdf2 hash used for unknown-account verification.
# Leave unset to use the built-in valid scrypt hash; never place plaintext here.
# LOGIN_DUMMY_PASSWORD_HASH=

# Structured login security audit events. Use a unique random value (32+ chars).
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_HMAC_KEY=replace_with_a_unique_random_security_audit_key

# Positive per-user calendar-month limit for successful synchronous AI calls.
MAX_AI_REQUESTS_PER_MONTH=500
